{
  "name": "sentinelswarm",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native crisis coordination agent for monsoon flood response.",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "smoke:slack": "tsx scripts/slack-smoke.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@slack/bolt": "^4.4.0",
    "@slack/web-api": "^7.11.0",
    "dotenv": "^17.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
